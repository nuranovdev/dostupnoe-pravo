# Supabase — required
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: service-role key. When set, server actions use it for writes so the
# app works regardless of RLS configuration. Never expose this to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram notifications (bonus) — optional.
# TELEGRAM_BOT_TOKEN is the shared bot secret (server-only).
# TELEGRAM_CHAT_ID is only a fallback: each tester can set their own chat id
# from the in-app "Notifications" dialog (stored per-browser). If neither a
# per-user chat id nor this fallback is set, the notification is skipped.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
