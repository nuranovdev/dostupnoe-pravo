# Supabase — required
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: service-role key. When set, server actions use it for writes so the
# app works regardless of RLS configuration. Never expose this to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram notifications (bonus) — optional.
# If either value is missing, the app simply skips the notification.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
